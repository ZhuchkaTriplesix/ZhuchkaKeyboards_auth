# FastAPI Application Configuration
# Copy this file to config.ini and adjust values for your environment

[POSTGRES]
# PostgreSQL database configuration
DATABASE = postgresql
DRIVER = asyncpg
DATABASE_NAME = your_database_name
USERNAME = postgres
PASSWORD = your_password  
IP = localhost
PORT = 5432

# Connection pool settings
DATABASE_ENGINE_POOL_TIMEOUT = 30
DATABASE_ENGINE_POOL_RECYCLE = 3600
DATABASE_ENGINE_POOL_SIZE = 5
DATABASE_ENGINE_MAX_OVERFLOW = 10
DATABASE_ENGINE_POOL_PING = true

# Database echo (SQL logging) - set to false in production
DATABASE_ECHO = false

[UVICORN]
# Granian ASGI (section name kept for compatibility): bind, workers, loop, HTTP mode
HOST = 0.0.0.0
PORT = 8000
WORKERS = 4

# Event loop: auto | asyncio | uvloop | winloop | rloop
LOOP = uvloop

# HTTP: auto | 1 | 2 (Granian)
HTTP = auto

[REDIS]
# Redis cache configuration  
HOST = localhost
PORT = 6379
DB = 0
PASSWORD =

[AUTH]
# Issuer URL must match public URL behind Traefik (no trailing slash in JWT iss)
ISSUER = http://127.0.0.1:8000
AUDIENCE = zhuchka-api
ACCESS_TOKEN_MINUTES = 15
REFRESH_TOKEN_DAYS = 30
JWT_PRIVATE_KEY_PATH = var/jwt_private.pem
# First admin + dev OAuth client (set in dev only; empty = skip)
BOOTSTRAP_ADMIN_EMAIL =
BOOTSTRAP_ADMIN_PASSWORD =
BOOTSTRAP_CLIENT_ID = zhuchka-dev
BOOTSTRAP_CLIENT_SECRET = change-me-dev-only
PASSWORD_GRANT_ENABLED = true

